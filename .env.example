# Where the dataset JSON is published (explorer_data.json + bar_opinions.json).
# Defaults to the live published copy at legalhack.io/data.
ORDERS_DATA_BASE=https://legalhack.io/data

# In-memory cache TTL for the fetched dataset (ms). Default 10 minutes.
ORDERS_CACHE_TTL_MS=600000

# ---- Chat (/chat + POST /api/chat) ----

# Which LLM provider powers the chat. Default: openrouter.
CHAT_PROVIDER=openrouter

# REQUIRED for the public chat path. Funded, rate-limited OpenRouter key.
OPENROUTER_API_KEY=
# Default model; a cheap DeepSeek model is used if unset.
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Optional alternative providers (set CHAT_PROVIDER accordingly). Server-only.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.1

# ---- Rate limiting (protects the funded key) ----
# REQUIRED for the public deploy. Without these, limiting falls back to a
# best-effort in-memory limiter (fine for local dev, NOT durable on Vercel).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional threshold overrides (defaults shown).
# RL_BURST=20            # per-IP burst (token bucket)
# RL_BURST_WINDOW_MS=3600000
# RL_DAILY=100           # per-IP requests/day
# RL_GLOBAL=2000         # total requests/day (global kill-switch)
