# Where the explorer publishes its dataset JSON (explorer_data.json + bar_opinions.json).
# Defaults to the explorer repo's GitHub raw data dir. Point at legalhack.io/data
# once the explorer deploys the data there.
ORDERS_DATA_BASE=https://raw.githubusercontent.com/legalrealist/AI-orders-explorer/main/charts/data

# In-memory cache TTL for the fetched dataset (ms). Default 10 minutes.
ORDERS_CACHE_TTL_MS=600000
